# Gemini API key for ADK agents (Vertex AI project/location works instead —
# set GCP_PROJECT + GCP_LOCATION and omit this)
GEMINI_API_KEY=
GCP_PROJECT=
GCP_LOCATION=

# smartloans_backend base URL this service calls for loan/client data
SMARTLOANS_BACKEND_URL=https://smartloansbackend.azurewebsites.net

# Port this service listens on (smartloans_backend's modules/loanChat.py
# calls POST {NEGOTIATION_AGENT_URL}/negotiate)
PORT=8080
